{
  "name": "uncommon-orgos",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @orgos/db generate",
    "db:migrate": "pnpm --filter @orgos/db migrate",
    "db:studio": "pnpm --filter @orgos/db studio",
    "db:seed": "pnpm --filter @orgos/db seed"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
